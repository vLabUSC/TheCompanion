# .gitignore for The Companion (public student bundle)
#
# student-only/ holds personal content the Companion writes for each student
# locally — project plans, notes, references they collect, session handoffs,
# instructor questions. None of that belongs in the public repo. The folder
# scaffolding (README + .gitkeep files) IS tracked so the structure ships
# with the bundle.

# Ignore everything inside student-only/ by default
student-only/**

# Keep the scaffolding so the folder structure ships
!student-only/README.md
!student-only/notes/
!student-only/notes/.gitkeep
!student-only/projects/
!student-only/projects/.gitkeep
!student-only/references/
!student-only/references/.gitkeep
